# ticket-dispatcher worker 环境配置（systemd EnvironmentFile）。
# 装到 /etc/ticket-dispatcher/worker.env，由 ticket-worker.service 读取。
# 改完执行：sudo systemctl restart ticket-worker
#
# 注意格式：systemd EnvironmentFile 是 KEY=VALUE，值不要加引号（除非引号是值的一部分）。

# ── 这台 worker 的身份 ──
WORKER_ID=worker_cloud
WORKER_PROGRAM=
MAX_SLOTS=1

# ── Redis（API 与 worker 必须连同一个）──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# 设了 requirepass 就填，否则留空（注意：连不上会让 worker 启动即失败，不再静默回退）
REDIS_PASSWORD=
